  "item": [
    {
      "name": "01_get_request",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "console.log('Sending GET request to: ' + pm.collectionVariables.get('baseUrl') + '/status');"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test('Status code is 200', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('API status is OK', function () {\r",
              "    pm.expect(jsonData.status).to.eql('OK');\r",
              "});\r",
              "\r",
              "// Intentional fail\r",
              "pm.test('Status should be OFFLINE', function () {\r",
              "    pm.expect(jsonData.status).to.eql('OFFLINE');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "status"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02_get_books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "const availableBook = jsonData.find(book => book.available === true);\r",
              "\r",
              "if (availableBook) {\r",
              "    pm.collectionVariables.set('bookId', availableBook.id);\r",
              "}\r",
              "\r",
              "pm.test('Books exist', function () {\r",
              "    pm.expect(jsonData.length).to.be.greaterThan(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books?type=fiction",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "books"
          ],
          "query": [
            {
              "key": "type",
              "value": "fiction"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "03_get_single_book",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test('Book has author', function () {\r",
              "    pm.expect(jsonData).to.have.property('author');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books/{{bookId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "books",
            "{{bookId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "04_post_request",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const randomNum = Math.floor(Math.random() * 100000);\r",
              "\r",
              "pm.collectionVariables.set(\r",
              "    'clientName',\r",
              "    'TestUser_' + randomNum\r",
              ");\r",
              "\r",
              "pm.collectionVariables.set(\r",
              "    'clientEmail',\r",
              "    'testuser' + randomNum + '@example.com'\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\r",
              "    'accessToken',\r",
              "    jsonData.accessToken\r",
              ");\r",
              "\r",
              "pm.test('Token exists', function () {\r",
              "    pm.expect(jsonData.accessToken).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "",
            "value": "application",
            "type": "text",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"clientName\": \"{{clientName}}\",\r\n  \"clientEmail\": \"{{clientEmail}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api-clients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api-clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "05_order_submit",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\r",
              "    'orderId',\r",
              "    jsonData.orderId\r",
              ");\r",
              "\r",
              "pm.test('Order created', function () {\r",
              "    pm.expect(jsonData.created).to.be.true;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"bookId\": {{bookId}},\r\n  \"customerName\": \"Farooque\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "orders"
          ]
        }
      },
      "response": []
    },
